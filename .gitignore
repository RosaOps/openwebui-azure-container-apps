# Terraform state — contains deployed resource IDs and generated secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/

# Variable file with subscription ID and domain (use terraform.tfvars.example as template)
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
*.override.tf
*.override.tf.json

# Claude Code settings
.claude/

# Documentation folder
documentation/

# Assessment PDF (optional — remove this line if you want to include it)
*.pdf
